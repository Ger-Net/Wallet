<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Wallet22.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Wallet22"
    xmlns:pages="clr-namespace:Wallet22.MVVM.View"
    Shell.FlyoutBehavior="Disabled"
    Title="Wallet22">
    
    <TabBar Route="MainPage">
        <Tab Title="Operations" Icon="op.png">
            <ShellContent ContentTemplate="{DataTemplate pages:OperationsPage}"/>
        </Tab>
        <Tab Title="Settings" Icon="set.png">
            <ShellContent ContentTemplate="{DataTemplate pages:SettingsPage}"/>
        </Tab>
    </TabBar>
</Shell>
